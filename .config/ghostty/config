# By default Reload config with shft + cmd + ,
# Reference: https://github.com/Sin-cy/dotfiles/blob/main/ghostty/.config/ghostty/config

config-file = themes/rosepine
background = #000000
background-opacity = 0.9
background-blur-radius = 14

font-family = IBM Plex Mono
font-family = IBM Plex Sans JP
font-size = 14.5
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

macos-titlebar-style = tabs
macos-option-as-alt = true
mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = true
window-padding-x = 20
window-padding-y = 20
window-padding-balance = true
window-height = 40
window-width = 130
shell-integration = zsh
window-save-state = always

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = no-cursor,ssh-terminfo,ssh-env
copy-on-select = clipboard

# Custom Keybinds & Config (super represents cmd key on mac)
# For Simple Keybinds
# keybind = super+r=reload_config
keybind = super+i=inspector:toggle
keybind = ctrl+b>,=toggle_quick_terminal

# Similar Tmux but with Ghostty
# (ctrl b for tmux -> cmb b for ghostty)
keybind = ctrl+b>r=reload_config

# タブ移動・ペイン分割・移動は herdr(prefix=ctrl+b) に委譲する。
# ここで ctrl+b>1..9 や ctrl+b>- / h/j/k/l を定義すると Ghostty が先にキーを
# 横取りし、herdr の prefix+n/prefix+h 等に届かなくなるため定義しない。

#Shaders
