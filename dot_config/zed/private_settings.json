// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "theme": "Cursor Dark",
  "theme_overrides": {
    "Cursor Dark": {
      "background": "#151515",
      "editor.background": "#151515",
      "editor.gutter.background": "#151515",
      "title_bar.background": "#151515",
      "title_bar.inactive_background": "#151515",
      "tab_bar.background": "#151515",
      "tab.active_background": "#151515",
      "tab.inactive_background": "#151515",
      "panel.background": "#151515",
      "status_bar.background": "#151515",
      "toolbar.background": "#151515",
      "terminal.background": "#151515",

      "border": "#1a1a1a",
      "border.variant": "#151515",
      "border.focused": "#1a1a1a",
      "panel.focused_border": "#1a1a1a",
      "pane.focused_border": "#1a1a1a",

      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",

      "text": "#e4e4e4",
      "text.muted": "#a0a0a0",
      "text.placeholder": "#6b6b6b",
      "text.disabled": "#5a5a5a",
      "text.accent": "#7aa2f7",

      "syntax": {
        "comment": { "font_style": "italic" },
        "comment.doc": { "font_style": "italic" },
      },
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "model": [
          "sonnet[1m]"
        ]
      },
      "type": "registry",
    },
    "opencode": {
      "type": "extension",
      "default_config_options": {},
      "favorite_config_option_values": {},
    },
  },
  "current_line_highlight": "all",
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "model_parameters": [],
  },
  "languages": {
    "Markdown": {
      "soft_wrap": "prefer_line",
      "auto_indent": "syntax_aware",
      "hard_tabs": false,
      "indent_guides": {
        "line_width": 1,
      },
      "preferred_line_length": 80,
      "tab_size": 2,
    },
  },
  "buffer_line_height": {
    "custom": 1.4,
  },
  "buffer_font_weight": 400.0,
  "agent_ui_font_size": 15.0,
  "agent_buffer_font_size": 14.0,
  "icon_theme": "Symbols Icon Theme",
  "ui_font_family": "IBM Plex Sans",
  "buffer_font_family": "IBM Plex Mono",
  "format_on_save": "on",
  "terminal": {
    "button": true,
    "font_family": "Hack Nerd Font Propo",
    "font_size": 14.0,
    "env": {
      "Q_NEW_SESSION": "1",
      "FIG_NEW_SESSION": "1",
      "CW_NEW_SESSION": "1",
    },
    "copy_on_select": true,
  },
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
  },
  "minimap": {
    "show": "never",
    "max_width_columns": 30,
  },
  "cursor_blink": false,
  "autosave": "on_focus_change",
  "linked_edits": true,
  "use_on_type_format": true,
  "indent_guides": {
    "enabled": false,
  },
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "file_types": {
    "php": ["*.twig"],
    "css": ["*.css"],
    "html": ["*.ejs", "*.html.ejs", "*.html.erb", "*html"],
    "typescriptreact": ["*.tsx"],
    "markdown": ["*.md"],
  },
  "base_keymap": "VSCode",
  "ui_font_size": 15.5,
  "buffer_font_size": 14.5,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "toolbar": {
    "quick_actions": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "scrollbar": {
    "show": "never",
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
}
