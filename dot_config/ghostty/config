# By default Reload config with shft + cmd + ,
# Reference: https://github.com/Sin-cy/dotfiles/blob/main/ghostty/.config/ghostty/config

config-file = themes/rosepine
background = #000000
background-opacity = 0.9
background-blur-radius = 14

font-family = "IBM Plex Mono", "IBM Plex Sans JP"
font-size = 14.5
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

macos-titlebar-style = tabs
macos-option-as-alt = true
mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = true
window-padding-x = 20
window-padding-y = 20
window-padding-balance = true
window-height = 40
window-width = 130
shell-integration = zsh
window-save-state = always

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = no-cursor,ssh-terminfo,ssh-env
copy-on-select = clipboard

# Custom Keybinds & Config (super represents cmd key on mac)
# For Simple Keybinds
# keybind = super+r=reload_config
keybind = super+i=inspector:toggle
keybind = ctrl+b>,=toggle_quick_terminal

# Similar Tmux but with Ghostty
# (ctrl b for tmux -> cmb b for ghostty)
keybind = ctrl+b>r=reload_config
keybind = ctrl+b>x=close_surface
# this only works if you have `macos-titlebar-style = tabs or native or transparent`
# else it behaves like new window
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>n=new_window

# tab nav
keybind = ctrl+b>1=goto_tab:1
keybind = ctrl+b>2=goto_tab:2
keybind = ctrl+b>3=goto_tab:3
keybind = ctrl+b>4=goto_tab:4
keybind = ctrl+b>5=goto_tab:5
keybind = ctrl+b>6=goto_tab:6
keybind = ctrl+b>7=goto_tab:7
keybind = ctrl+b>8=goto_tab:8
keybind = ctrl+b>9=goto_tab:9

# splitting
keybind = ctrl+b>\=new_split:right
keybind = ctrl+b>-=new_split:down
keybind = ctrl+b>e=equalize_splits

# split nav (setting this to control will not work if tmux already uses it)
keybind = ctrl+b>h=goto_split:left
keybind = ctrl+b>j=goto_split:bottom
keybind = ctrl+b>k=goto_split:top
keybind = ctrl+b>l=goto_split:right

